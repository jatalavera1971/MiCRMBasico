# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# convex
/convex/_generated

# typescript
*.tsbuildinfo
next-env.d.ts

# materiales del curso / no forman parte de la app
/Teoría/
/tmp/

# configuración local de Claude Code (personal, no compartida)
.claude/settings.local.json

# diseño: mantenemos design.md como referencia, pero no el export pesado del prototipo
/design/uploads/
/design/*.zip
/design/CRM Prototype Paginas/
